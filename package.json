{
  "name": "@waywake/wdt-sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for WangDianTong OpenAPI.",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "https://github.com/waywake/wdt-sdk-ts"
  },
  "bugs": {
    "url": "https://github.com/waywake/wdt-sdk-ts/issues"
  },
  "homepage": "https://github.com/waywake/wdt-sdk-ts#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "generate:endpoints": "bun run scripts/generate-endpoints.ts",
    "build": "bun run clean && bun build src/index.ts --outdir dist --target node --format esm --sourcemap=external && tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "wangdiantong",
    "wdt",
    "sdk",
    "typescript",
    "bun"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "1.3.14",
    "typescript": "5.9.3"
  }
}
